{
  "name": "ai-context-runner",
  "displayName": "AI Context Runner",
  "description": "Stateful AI session manager — auto-injects context into any AI agent on workspace open",
  "version": "2.4.0",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigfnj/ai-context-vscode-extension.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai.runTask",
        "title": "AI: Run Task"
      },
      {
        "command": "ai.setActiveContext",
        "title": "AI: Set Active Context"
      },
      {
        "command": "ai.viewContext",
        "title": "AI: View Context"
      },
      {
        "command": "ai.newContext",
        "title": "AI: New Context"
      },
      {
        "command": "ai.deleteContext",
        "title": "AI: Delete Context"
      },
      {
        "command": "ai.cleanUpContexts",
        "title": "AI: Clean Up Contexts"
      },
      {
        "command": "ai.restoreContext",
        "title": "AI: Restore Archived Context"
      }
    ],
    "keybindings": [
      {
        "command": "ai.runTask",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "ai.setActiveContext",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s"
      }
    ],
    "configuration": {
      "title": "AI Context Runner",
      "properties": {
        "aiContext.projectsRoot": {
          "type": "string",
          "default": "",
          "markdownDescription": "Root folder containing your projects. Used for the project picker when creating contexts.\n\nExample (WSL): `/home/Vibe-Projects`\n\nLeave blank to use `~/projects`."
        },
        "aiContext.agents": {
          "type": "array",
          "default": ["claude", "codex", "copilot"],
          "items": {
            "type": "string",
            "enum": ["claude", "codex", "copilot", "cursor", "windsurf", "kilo"]
          },
          "markdownDescription": "AI agents to inject context for on workspace open.\n\n| Value | File written |\n|---|---|\n| `claude` | `CLAUDE.md` |\n| `codex` | `AGENTS.md` |\n| `copilot` | `.github/copilot-instructions.md` |\n| `cursor` | `.cursorrules` |\n| `windsurf` | `.windsurfrules` |\n| `kilo` | `KILO.md` |"
        }
      }
    }
  }
}
