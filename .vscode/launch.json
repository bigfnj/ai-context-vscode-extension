{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}"
            ],
            "outFiles": [
                "${workspaceFolder}/src/**/*.js"
            ],
            "env": {
                "VSCODE_DEV": "1"
            }
        },
        {
            "name": "Run Extension (WSL)",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "--remote",
                "wsl+Ubuntu-24.04"
            ],
            "outFiles": [
                "${workspaceFolder}/src/**/*.js"
            ]
        }
    ]
}
